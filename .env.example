# Relational DB (backend persistence)
DATABASE_URL="postgresql://user:password@localhost:5432/jingxin"

# query_database MCP tool backend (HTTP service)
QUERY_DATABASE_URL="http://your-database-api-host:6200"

# Dify Configuration
DIFY_URL="http://your-dify-host:3001/v1"
DIFY_API_KEY="your-dify-api-key"
# Optional: only expose/allow these dataset IDs (comma/newline/semicolon separated)
# DIFY_ALLOWED_DATASET_IDS="e03f70ed-53b6-455a-b05e-460e19ba7c11,9496d0c2-269e-41fd-bc75-b8c12f7c0131"

# Tavily Search API
TAVILY_API_KEY="your-tavily-api-key"

# Model Configuration
# Backend port & URL
# PORT controls: Docker port mapping, nginx proxy port, backend listen port
# VITE_API_BASE_URL controls: URL baked into JS bundle for browser-side API calls
# The port in VITE_API_BASE_URL must match PORT
BACKEND_PORT=3001
FRONTEND_PORT=3002
VITE_API_BASE_URL=http://your-server-ip:3001

MODEL_URL="http://your-model-host:3001/v1"
API_KEY="your-api-key"

# Industry API Configuration
INDUSTRY_AUTH_TOKEN="your-industry-auth-token"
INDUSTRY_URL="https://your-industry-api.com/api"

# Model Names
BASE_MODEL_NAME="deepseek-chat"
QWEN_MODEL_NAME="qwen3_80b"
SUMMARIZE_MODEL_NAME="qwen3_80b"
# Summary Feature Toggle
# Set to "false" to disable AI conversation title summarization (falls back to message truncation)
ENABLE_SUMMARY=true
# Number of conversation rounds (user+assistant = 1 round) to update the summary title.
# After this many rounds the topic is considered stable and summary stops updating.
SUMMARY_MAX_ROUNDS=3

# Optional: Skills Configuration
# JINGXIN_USER_SKILLS_DIR=~/.jingxin-agent/skills
# JINGXIN_PROJECT_SKILLS_DIR=.jingxin/skills
# JINGXIN_DISABLE_USER_SKILLS=0
# JINGXIN_DISABLE_PROJECT_SKILLS=0

# Environment
ENVIRONMENT="dev"
TZ="Asia/Shanghai"
# Minimal images (prometheus/jaeger/alertmanager) may require fixed-offset TZ syntax
TZ_PROMETHEUS="CST-8"
TZ_JAEGER="CST-8"
TZ_ALERTMANAGER="CST-8"

# Storage Configuration
# Storage type: 'local' (default) or 's3'
STORAGE_TYPE="local"

# Local Storage Configuration (when STORAGE_TYPE=local)
STORAGE_PATH="./storage"

# S3 Storage Configuration (when STORAGE_TYPE=s3)
# S3_BUCKET="your-bucket-name"
# S3_ENDPOINT="https://s3.amazonaws.com"  # Optional, for S3-compatible services
# S3_REGION="us-east-1"
# S3_ACCESS_KEY="your-access-key"
# S3_SECRET_KEY="your-secret-key"
# S3_CDN_DOMAIN="cdn.example.com"  # Optional, for CDN-accelerated access
# S3_PRESIGNED_URL_EXPIRY="900"  # Default: 900 seconds (15 minutes)

# Logging Configuration
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL
ENV="dev"  # dev, staging, prod (affects log format)
# Optional file logging (backend)
LOG_TO_FILE="false"
LOG_FILE_PATH="/app/logs/backend.log"
LOG_FILE_MAX_BYTES="10485760"   # 10MB
LOG_FILE_BACKUP_COUNT="5"

# Metrics Configuration
METRICS_ENABLED="true"
METRICS_PORT="9090"

# Tracing Configuration
TRACING_ENABLED="false"  # Set to "true" to enable distributed tracing
JAEGER_HOST="localhost"
JAEGER_PORT="6831"
SERVICE_NAME="jingxin-agent"

# Alerting Configuration (for production)
# ALERT_WEBHOOK="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"
# PAGERDUTY_SERVICE_KEY="your-pagerduty-key"
# ALERT_EMAIL_TO="ops@example.com"
# ALERT_EMAIL_FROM="alerts@example.com"
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USERNAME="your-smtp-user"
# SMTP_PASSWORD="your-smtp-password"

# Rate Limiting Configuration
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_STORAGE="memory://"  # or "redis://localhost:6379"
RATE_LIMIT_GLOBAL="500/minute"
RATE_LIMIT_PER_USER="50/minute"

# Circuit Breaker Configuration
CB_USER_CENTER_THRESHOLD="5"  # Number of failures before opening
CB_USER_CENTER_TIMEOUT="60"   # Seconds to wait before retrying
CB_MODEL_API_THRESHOLD="10"
CB_MODEL_API_TIMEOUT="30"
CB_STORAGE_THRESHOLD="5"
CB_STORAGE_TIMEOUT="60"

# Request Size Limit
MAX_REQUEST_SIZE="10485760"  # 10MB in bytes

# Database Connection Pool
DB_POOL_SIZE="50"
DB_POOL_MAX_OVERFLOW="10"
DB_POOL_TIMEOUT="30"

# CORS Configuration (production)
# CORS_ORIGINS="https://jingxin.example.com,https://app.jingxin.example.com"

# User Center Authentication
# AUTH_MODE="remote"  # Options: "remote" (production), "mock" (development)
# AUTH_API_URL="https://user-center.example.com/api"
# AUTH_API_TIMEOUT="5"  # Timeout in seconds
# AUTH_RETRY_COUNT="2"  # Number of retries
# AUTH_MOCK_USER_ID="dev_user_001"  # Mock user ID for development
# AUTH_MOCK_USERNAME="Developer"  # Mock username for development

# Security Headers
# ENABLE_SECURITY_HEADERS="true"  # Enable security response headers in production

# Session Configuration
# SESSION_COOKIE_SECURE="true"  # Use secure cookies in production (HTTPS only)
# SESSION_COOKIE_HTTPONLY="true"  # Prevent JavaScript access to cookies
# SESSION_COOKIE_SAMESITE="strict"  # CSRF protection

# Audit Log Configuration
# AUDIT_LOG_RETENTION_DAYS="90"  # Audit log retention period
# AUDIT_LOG_EXPORT_ENABLED="true"  # Allow audit log export

# Data Masking
# ENABLE_LOG_MASKING="true"  # Automatically mask sensitive data in logs

# Admin panel token (required for POST/PUT to /v1/content/docs/*)
ADMIN_TOKEN="your-secret-admin-token"

# Config management panel token (required for /v1/config/*, /v1/models/*, /v1/admin/usage-logs/*, etc.)
CONFIG_TOKEN="your-secret-config-token"

# ════════════════════════════════════════════════════════════════
#  mem0 记忆系统配置
# ════════════════════════════════════════════════════════════════

# 全局开关（后端层面，为 false 时所有记忆功能完全跳过）
MEM0_ENABLED=false

# 图记忆开关（需先确保 Neo4j 正常运行后再考虑开启）
MEM0_GRAPH_ENABLED=false

# ── Embedding 服务（OpenAI 兼容接口）────────────────────────────
MEM0_EMBED_URL=http://101.37.174.109:3001/v1
MEM0_EMBED_API_KEY=sk-GKZEn9QR5t0OZHPRB8FfF3AaA95f4aAc812b73B074E79492
MEM0_EMBED_MODEL=qwen3_embedding_8b
MEM0_EMBED_DIMS=1024

# ── Milvus 向量数据库 ──────────────────────────────────────────
MILVUS_URL=http://milvus:19530

# ── Reranker 重排模型（可选，与 Embedding 服务同一地址）─────────
# 填入 RERANKER_MODEL 后自动生效；留空则不启用重排
RERANKER_URL=http://101.37.174.109:3001/v1
RERANKER_API_KEY=sk-GKZEn9QR5t0OZHPRB8FfF3AaA95f4aAc812b73B074E79492
RERANKER_MODEL=

# ── Neo4j 图数据库（可选，MEM0_GRAPH_ENABLED=true 时使用）──────
NEO4J_URL=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
