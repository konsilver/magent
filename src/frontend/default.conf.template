server {
    listen 80;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # index.html 不缓存，确保每次发布后浏览器能拿到最新入口
    location = /index.html {
        try_files $uri =404;
        add_header Cache-Control "no-store, no-cache, must-revalidate" always;
    }

    # 带内容哈希的静态资源（JS/CSS）长期缓存
    location /assets/ {
        try_files $uri =404;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
    }

    # 操作手册 PDF 静态文件（来自共享 volume）
    location /docs/manual/ {
        alias /usr/share/nginx/html/docs/manual/;
        try_files $uri =404;
        add_header Cache-Control "no-cache" always;
    }

    # 其余路径（SPA fallback）
    location / {
        try_files $uri $uri/ /index.html;
    }

    # API proxy — port resolved from BACKEND_PORT env var at container startup
    location /api/ {
        proxy_pass http://backend:${BACKEND_PORT}/;
        client_max_body_size 50m;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 禁用缓冲，保证 SSE 流式输出实时透传
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    # Mock SSO proxy — backend serves the login page directly
    location /mock-sso/ {
        proxy_pass http://backend:${BACKEND_PORT}/mock-sso/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "no-referrer-when-downgrade" always;
}
