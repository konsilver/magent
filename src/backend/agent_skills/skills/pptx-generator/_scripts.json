[
  {
    "name": "scripts/build_presentation.js",
    "description": "Build a PPTX deck from a JSON payload",
    "language": "javascript",
    "timeout": 120,
    "input_mode": "stdin_json",
    "params_schema": {
      "type": "object",
      "required": ["slides"],
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "subject": { "type": "string" },
        "out": { "type": "string" },
        "theme": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": "string" },
            "accent": { "type": "string" },
            "light": { "type": "string" },
            "bg": { "type": "string" }
          }
        },
        "slides": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["type", "title"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["cover", "toc", "section", "content", "summary"]
              },
              "title": { "type": "string" },
              "subtitle": { "type": "string" },
              "body": { "type": "string" },
              "bullets": {
                "type": "array",
                "items": { "type": "string" }
              },
              "items": {
                "type": "array",
                "items": { "type": "string" }
              },
              "leftTitle": { "type": "string" },
              "rightTitle": { "type": "string" },
              "leftBullets": {
                "type": "array",
                "items": { "type": "string" }
              },
              "rightBullets": {
                "type": "array",
                "items": { "type": "string" }
              },
              "highlights": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },
  {
    "name": "scripts/extract_text.sh",
    "description": "Extract PPTX text content via markitdown",
    "language": "bash",
    "timeout": 60,
    "input_mode": "cli_args"
  }
]
